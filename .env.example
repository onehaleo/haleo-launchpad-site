# Optional: override Formspree URL (app defaults to https://formspree.io/f/mojrjebn).
# VITE_WORKFLOW_FORM_ENDPOINT=https://formspree.io/f/your-other-form

# Internal /admin — same GitHub OAuth proxy as Decap CMS (defaults to https://cms-oauth-github.vercel.app).
# Add every browser host that opens /admin to the proxy ORIGIN env (e.g. https://admin.onehaleo.com).
# VITE_CMS_OAUTH_BASE_URL=https://cms-oauth-github.vercel.app
# VITE_ADMIN_SITE_ID=admin.onehaleo.com
# VITE_ADMIN_ALLOWED_GITHUB_USERS=yourgithublogin
